import rally.notes
import rally.issue_ledger
import rally.memory


output shape RallyEnvText: "Rally Env Text"
    kind: PlainText


input RallyWorkspaceDir: "Rally Workspace Dir"
    source: EnvVar
        env: "RALLY_WORKSPACE_DIR"
    shape: DirectoryPath
    requirement: Required
    "Read this environment variable as the absolute path to the active Rally workspace root."


input RallyRunId: "Rally Run ID"
    source: EnvVar
        env: "RALLY_RUN_ID"
    shape: RallyEnvText
    requirement: Required
    "Read this environment variable as the active Rally run id."


input RallyFlowCode: "Rally Flow Code"
    source: EnvVar
        env: "RALLY_FLOW_CODE"
    shape: RallyEnvText
    requirement: Required
    "Read this environment variable as the active Rally flow code."


input RallyAgentSlug: "Rally Agent Slug"
    source: EnvVar
        env: "RALLY_AGENT_SLUG"
    shape: RallyEnvText
    requirement: Required
    "Read this environment variable as the active compiled agent slug for this turn."


skill RallyKernelSkill: "rally-kernel"
    purpose: "Use the shared Rally kernel skill when you need one saved run note or the final JSON for this turn."

    use_when: "Use When"
        "Use this when a later reader needs one short saved note."
        "Use this when the turn needs Rally's final JSON rules."


inputs RallyManagedInputs: "Inputs"
    rally_workspace_dir: "Rally Workspace Dir"
        RallyWorkspaceDir

    rally_run_id: "Rally Run ID"
        RallyRunId

    rally_flow_code: "Rally Flow Code"
        RallyFlowCode

    rally_agent_slug: "Rally Agent Slug"
        RallyAgentSlug

    issue_ledger: "Shared Ledger File"
        rally.issue_ledger.RallyIssueLedger


skills RallyManagedSkills: "Skills"
    skill rally_kernel: RallyKernelSkill
        requirement: Required
        reason: "Rally provides this skill on every Rally-managed turn."

    skill rally_memory: rally.memory.RallyMemorySkill
        requirement: Required
        reason: "Rally provides this skill on every Rally-managed turn."


outputs RallyManagedOutputs: "Outputs"
    issue_note: "Saved Run Note"
        rally.notes.RallyIssueNote


# This shared base block is where Rally states repo-wide turn rules once.
# Local flows can add more rules, but they should not fight this base layer.
abstract agent RallyManagedBaseAgent:
    rally_contract: "Rally Context"
        "Rally owns the run home, the shared ledger, and the final JSON for this turn."
        "The shared ledger file is `home:issue.md`."
        "For this turn, read skills from `home:skills/`."
        "On Codex turns, that same folder is `$CODEX_HOME/skills/`."
        "Read run identity from `RALLY_WORKSPACE_DIR`, `RALLY_RUN_ID`, `RALLY_FLOW_CODE`, and `RALLY_AGENT_SLUG`."
        "Use `RALLY_CLI_BIN` when a flow tells you to call the Rally CLI."

    read_first: rally.memory.RallyReadFirst
    how_to_take_a_turn: rally.memory.RallyHowToTakeATurn

    inputs: RallyManagedInputs
    skills: RallyManagedSkills
    outputs: RallyManagedOutputs
