{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RallyTurnResult",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "handoff",
        "done",
        "blocker",
        "sleep"
      ]
    },
    "next_owner": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "summary": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "reason": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "sleep_duration_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "agent_issues": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "kind",
    "next_owner",
    "summary",
    "reason",
    "sleep_duration_seconds"
  ],
  "additionalProperties": false
}
