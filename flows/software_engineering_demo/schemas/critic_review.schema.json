{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CriticReview",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "accept",
        "changes_requested"
      ]
    },
    "reviewed_artifact": {
      "type": "string",
      "minLength": 1
    },
    "analysis_performed": {
      "type": "string",
      "minLength": 1
    },
    "findings_first": {
      "type": "string",
      "minLength": 1
    },
    "current_artifact": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "next_owner": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "failure_detail": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "blocked_gate": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "failing_gates": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      },
      "required": [
        "blocked_gate",
        "failing_gates"
      ]
    }
  },
  "required": [
    "verdict",
    "reviewed_artifact",
    "analysis_performed",
    "findings_first",
    "current_artifact",
    "next_owner",
    "failure_detail"
  ]
}
