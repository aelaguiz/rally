import rally.base_agent as base
import rally.turn_results as turn_results
from rally.memory import RallyMemorySkill


inputs SoftwareEngineeringDemoInputs[base.RallyManagedInputs]: "Inputs"
    inherit issue_ledger

    demo_repo_root: DemoRepoRoot


output schema ArchitectTurnResultSchema[turn_results.BaseRallyTurnResultSchema]: "Architect Turn Result Schema"
    route field next_route: "Next Route"
        architect_reviewer: "Send the issue to ArchitectReviewer." -> ArchitectReviewer
        nullable
        note: "Use null only when the architect turn blocks or sleeps."

    inherit {kind, summary, reason, sleep_duration_seconds, agent_issues}


output shape ArchitectTurnResultJson[turn_results.BaseRallyTurnResultJson]: "Architect Turn Result JSON"
    inherit kind
    override schema: ArchitectTurnResultSchema

    override field_notes: "Field Notes"
        bullets rules:
            "Always send every field in this schema."
            "Use `null` for fields that do not apply."
            "Use `handoff` when `next_route` is `architect_reviewer`."
            "Do not use `done` here."
            "Use null for `next_route` only when you block or sleep."


output ArchitectTurnResult[turn_results.BaseRallyTurnResult]: "Architect Turn Result"
    inherit target
    override shape: ArchitectTurnResultJson
    inherit requirement

    next_route: "Next Route" when route.exists
        "Use `architect_reviewer` when the architect pass is ready for review."


output schema DeveloperTurnResultSchema[turn_results.BaseRallyTurnResultSchema]: "Developer Turn Result Schema"
    route field next_route: "Next Route"
        developer_reviewer: "Send the issue to DeveloperReviewer." -> DeveloperReviewer
        nullable
        note: "Use null only when the developer turn blocks or sleeps."

    inherit {kind, summary, reason, sleep_duration_seconds, agent_issues}


output shape DeveloperTurnResultJson[turn_results.BaseRallyTurnResultJson]: "Developer Turn Result JSON"
    inherit kind
    override schema: DeveloperTurnResultSchema

    override field_notes: "Field Notes"
        bullets rules:
            "Always send every field in this schema."
            "Use `null` for fields that do not apply."
            "Use `handoff` when `next_route` is `developer_reviewer`."
            "Do not use `done` here."
            "Use null for `next_route` only when you block or sleep."


output DeveloperTurnResult[turn_results.BaseRallyTurnResult]: "Developer Turn Result"
    inherit target
    override shape: DeveloperTurnResultJson
    inherit requirement

    next_route: "Next Route" when route.exists
        "Use `developer_reviewer` when the developer pass is ready for review."


output schema QaDocsTurnResultSchema[turn_results.BaseRallyTurnResultSchema]: "QA Docs Turn Result Schema"
    route field next_route: "Next Route"
        qa_reviewer: "Send the issue to QaReviewer." -> QaReviewer
        nullable
        note: "Use null only when the QA docs turn blocks or sleeps."

    inherit {kind, summary, reason, sleep_duration_seconds, agent_issues}


output shape QaDocsTurnResultJson[turn_results.BaseRallyTurnResultJson]: "QA Docs Turn Result JSON"
    inherit kind
    override schema: QaDocsTurnResultSchema

    override field_notes: "Field Notes"
        bullets rules:
            "Always send every field in this schema."
            "Use `null` for fields that do not apply."
            "Use `handoff` when `next_route` is `qa_reviewer`."
            "Do not use `done` here."
            "Use null for `next_route` only when you block or sleep."


output QaDocsTurnResult[turn_results.BaseRallyTurnResult]: "QA Docs Turn Result"
    inherit target
    override shape: QaDocsTurnResultJson
    inherit requirement

    next_route: "Next Route" when route.exists
        "Use `qa_reviewer` when the QA pass is ready for review."


skills RepoWorkSkills: "Skills And Tools"
    skill rally_kernel: base.RallyKernelSkill
        requirement: Required

    skill demo_git: DemoGitSkill
        requirement: Required

    skill repo_search: RepoSearchSkill
        requirement: Advisory


# Architect opts into the shared `rally-memory` system skill.
# flow.yaml declares the opt-in under `system_skills`; this block binds the
# same skill so the compiled readback matches the allowlist surface.
skills RepoWorkSkillsWithMemory[RepoWorkSkills]: "Skills And Tools"
    inherit {rally_kernel, demo_git, repo_search}

    skill rally_memory: RallyMemorySkill
        requirement: Advisory


skills RepoProofSkills: "Skills And Tools"
    skill rally_kernel: base.RallyKernelSkill
        requirement: Required

    skill demo_git: DemoGitSkill
        requirement: Required

    skill repo_search: RepoSearchSkill
        requirement: Advisory

    skill pytest_local: PytestLocalSkill
        requirement: Advisory


abstract agent SoftwareEngineeringRole[base.RallyManagedBaseAgent]:
    inherit {rally_contract, read_first, how_to_take_a_turn}
    system_context: SoftwareEngineeringSystemContext
    issue_truth: IssueLedgerGroundTruth
    repo_rules: DemoRepoRules


agent Architect[SoftwareEngineeringRole]:
    role: "Core job: turn the issue into one real next build step for the demo repo."
    inherit {rally_contract, read_first, how_to_take_a_turn, system_context, issue_truth, repo_rules}
    decision: ArchitectureChoice
    your_job: ArchitectJob
    quality_bar: ArchitectQualityBar
    inputs: SoftwareEngineeringDemoInputs
    skills: RepoWorkSkillsWithMemory
    outputs[base.RallyManagedOutputs]: "Outputs"
        # Keep `Turn Result` explicit because the wrapper title still helps the
        # emitted readback. `override issue_note:` stays short because it keeps
        # the inherited `Saved Run Note` title.
        override issue_note: ArchitectIssueNote

        turn_result: "Turn Result"
            ArchitectTurnResult
    final_output:
        output: ArchitectTurnResult
        route: next_route


agent ArchitectReviewer[SoftwareEngineeringRole]:
    role: "Core job: review the architect pass honestly and route the next real owner."
    inherit {rally_contract, read_first, how_to_take_a_turn, system_context, issue_truth, repo_rules}
    your_job: ArchitectReviewerJob
    quality_bar: ArchitectReviewerQualityBar
    review: ArchitectReview
    inputs: SoftwareEngineeringDemoInputs
    skills: RepoWorkSkills
    # Keep this wrapper explicit because it carries two direct outputs under one
    # local title.
    outputs: "Outputs"
        EngineeringReviewResponse
        EngineeringReviewFinalResponse
    final_output:
        output: EngineeringReviewFinalResponse
        review_fields:
            verdict
            reviewed_artifact
            analysis: analysis_performed
            readback: findings_first
            current_artifact
            blocked_gate: failure_detail.blocked_gate
            failing_gates: failure_detail.failing_gates
            next_owner


agent Developer[SoftwareEngineeringRole]:
    role: "Core job: make the next real repo change for the issue."
    inherit {rally_contract, read_first, how_to_take_a_turn, system_context, issue_truth, repo_rules}
    your_job: DeveloperJob
    quality_bar: DeveloperQualityBar
    inputs: SoftwareEngineeringDemoInputs
    skills: RepoProofSkills
    outputs[base.RallyManagedOutputs]: "Outputs"
        override issue_note: DeveloperIssueNote

        turn_result: "Turn Result"
            DeveloperTurnResult
    final_output:
        output: DeveloperTurnResult
        route: next_route


agent DeveloperReviewer[SoftwareEngineeringRole]:
    role: "Core job: review the developer pass honestly and route the next real owner."
    inherit {rally_contract, read_first, how_to_take_a_turn, system_context, issue_truth, repo_rules}
    your_job: DeveloperReviewerJob
    quality_bar: DeveloperReviewerQualityBar
    review: DeveloperReview
    inputs: SoftwareEngineeringDemoInputs
    skills: RepoWorkSkills
    outputs: "Outputs"
        EngineeringReviewResponse
        EngineeringReviewFinalResponse
    final_output:
        output: EngineeringReviewFinalResponse
        review_fields:
            verdict
            reviewed_artifact
            analysis: analysis_performed
            readback: findings_first
            current_artifact
            blocked_gate: failure_detail.blocked_gate
            failing_gates: failure_detail.failing_gates
            next_owner


agent QaDocsTester[SoftwareEngineeringRole]:
    role: "Core job: prove the change, repair small docs or test gaps, and hand the result to QaReviewer."
    inherit {rally_contract, read_first, how_to_take_a_turn, system_context, issue_truth, repo_rules}
    your_job: QaDocsTesterJob
    quality_bar: QaDocsTesterQualityBar
    inputs: SoftwareEngineeringDemoInputs
    skills: RepoProofSkills
    outputs[base.RallyManagedOutputs]: "Outputs"
        override issue_note: QaIssueNote

        turn_result: "Turn Result"
            QaDocsTurnResult
    final_output:
        output: QaDocsTurnResult
        route: next_route


agent QaReviewer[SoftwareEngineeringRole]:
    role: "Core job: review the QA pass honestly and end only when the issue is truly done."
    inherit {rally_contract, read_first, how_to_take_a_turn, system_context, issue_truth, repo_rules}
    your_job: QaReviewerJob
    quality_bar: QaReviewerQualityBar
    review: QaReview
    inputs: SoftwareEngineeringDemoInputs
    skills: RepoWorkSkills
    outputs: "Outputs"
        EngineeringReviewResponse
        EngineeringReviewFinalResponse
    final_output:
        output: EngineeringReviewFinalResponse
        review_fields:
            verdict
            reviewed_artifact
            analysis: analysis_performed
            readback: findings_first
            current_artifact
            blocked_gate: failure_detail.blocked_gate
            failing_gates: failure_detail.failing_gates
            next_owner
