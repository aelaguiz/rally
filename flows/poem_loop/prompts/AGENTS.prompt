import rally.base_agent
import rally.turn_results
import shared.inputs
import shared.outputs
import shared.contracts
import shared.review
import roles.muse
import roles.poem_writer
import roles.poem_critic


inputs PoemLoopInputs[rally.base_agent.RallyManagedInputs]: "Inputs"
    inherit issue_ledger

    poem_draft_file:
        shared.inputs.PoemDraftFile


input PreviousMuseTurn: "Previous Muse Turn"
    source: rally.base_agent.RallyPreviousTurnOutput
    requirement: Advisory
    "Use the exact previous Muse turn JSON when PoemWriter starts a new draft."


input PreviousPoemReview: "Previous Poem Review"
    source: rally.base_agent.RallyPreviousTurnOutput
        output: shared.review.PoemReviewFinalResponse
    requirement: Advisory
    "Use the exact previous PoemCritic review JSON when Muse is revising after a reject loop."


inputs MuseInputs[PoemLoopInputs]: "Muse Inputs"
    inherit issue_ledger
    inherit poem_draft_file

    previous_poem_review:
        PreviousPoemReview


inputs WriterInputs[PoemLoopInputs]: "Writer Inputs"
    inherit issue_ledger
    inherit poem_draft_file

    previous_muse_turn:
        PreviousMuseTurn


output schema MuseTurnResultSchema[rally.turn_results.BaseRallyTurnResultSchema]: "Muse Turn Result Schema"
    route field next_route: "Next Route"
        poem_writer: "Send the guidance to PoemWriter." -> PoemWriter
        nullable
        note: "Use null only when Muse must block or sleep."

    inherit kind
    inherit summary
    inherit reason
    inherit sleep_duration_seconds

    field poem_type: "Poem Type"
        type: string
        nullable
        min_length: 1
        note: "The poem type Muse wants next."

    field subject: "Subject"
        type: string
        nullable
        min_length: 1
        note: "The poem subject Muse wants next."

    field creative_direction: "Creative Direction"
        type: string
        nullable
        min_length: 1
        note: "The main image, mood, or angle for the next draft."

    field revision_goal: "Revision Goal"
        type: string
        nullable
        min_length: 1
        note: "The clearest thing PoemWriter should fix or sharpen next."


output shape MuseTurnResultJson[rally.turn_results.BaseRallyTurnResultJson]: "Muse Turn Result JSON"
    inherit kind
    override schema: MuseTurnResultSchema

    override field_notes: "Field Notes"
        bullets rules:
            "Always send every field in this schema."
            "Use `null` for fields that do not apply."
            "`kind` tells Rally what to do next."
            "Use `handoff` when `next_route` is `poem_writer`."
            "Do not use `done` here."
            "Use `null` for `next_route` only when you block or sleep."
            "Set the poem fields when you hand off a new draft direction."


output MuseTurnResult[rally.turn_results.BaseRallyTurnResult]: "Muse Turn Result"
    inherit target
    override shape: MuseTurnResultJson
    inherit requirement

    next_route: "Next Route" when route.exists
        "Use `poem_writer` when the next draft direction is clear."

    poem_type: "Poem Type"
        "Name the poem type Muse wants next."

    subject: "Subject"
        "Name the subject Muse wants next."

    creative_direction: "Creative Direction"
        "Name the main image, mood, or angle for the next draft."

    revision_goal: "Revision Goal"
        "Name the clearest thing PoemWriter should fix or sharpen next."


output schema PoemWriterTurnResultSchema[rally.turn_results.BaseRallyTurnResultSchema]: "Poem Writer Turn Result Schema"
    route field next_route: "Next Route"
        poem_critic: "Send the draft to PoemCritic." -> PoemCritic
        nullable
        note: "Use null only when the writer must block or sleep."

    inherit kind
    inherit summary
    inherit reason
    inherit sleep_duration_seconds

    field inspiration: "Inspiration"
        type: string
        nullable
        min_length: 1
        note: "Short image, mood, or idea that shaped the draft."


output shape PoemWriterTurnResultJson[rally.turn_results.BaseRallyTurnResultJson]: "Poem Writer Turn Result JSON"
    inherit kind
    override schema: PoemWriterTurnResultSchema

    override field_notes: "Field Notes"
        bullets rules:
            "Always send every field in this schema."
            "Use `null` for fields that do not apply."
            "`kind` tells Rally what to do next."
            "Use `handoff` when `next_route` is `poem_critic`."
            "Do not use `done` here."
            "Use `null` for `next_route` only when you block or sleep."
            "Set `inspiration` to one short phrase when you hand off a draft."
            "Use `null` for `inspiration` when you block or sleep."


output PoemWriterTurnResult[rally.turn_results.BaseRallyTurnResult]: "Poem Writer Turn Result"
    inherit target
    override shape: PoemWriterTurnResultJson
    inherit requirement

    next_route: "Next Route" when route.exists
        "Use `poem_critic` when the draft is ready for review."

    inspiration: "Inspiration"
        "Name one short image, mood, or idea that shaped the draft."
        "Use `null` when you block or sleep."


abstract agent PoemLoopRole[rally.base_agent.RallyManagedBaseAgent]:
    inherit rally_contract
    inherit read_first
    inherit how_to_take_a_turn
    system_context: shared.contracts.PoemLoopSystemContext
    ground_truth: shared.contracts.IssueLedgerGroundTruth
    primary_path: shared.contracts.PrimaryPathRules


agent Muse[PoemLoopRole]:
    role: "Core job: turn the brief or latest critic review into one clear next draft direction for PoemWriter."
    inherit rally_contract
    inherit read_first
    inherit how_to_take_a_turn
    inherit system_context
    inherit ground_truth
    inherit primary_path
    your_job: roles.muse.MuseJob
    quality_bar: roles.muse.MuseQualityBar
    inputs: MuseInputs
    outputs[rally.base_agent.RallyManagedOutputs]: "Outputs"
        inherit issue_note

        turn_result: "Turn Result"
            MuseTurnResult
    skills: rally.base_agent.RallyManagedSkills
    final_output:
        output: MuseTurnResult
        route: next_route


agent PoemWriter[PoemLoopRole]:
    role: "Core job: turn Muse guidance into the requested poem and hand it to PoemCritic."
    inherit rally_contract
    inherit read_first
    inherit how_to_take_a_turn
    inherit system_context
    inherit ground_truth
    inherit primary_path
    your_job: roles.poem_writer.PoemWriterJob
    quality_bar: roles.poem_writer.PoemWriterQualityBar
    inputs: WriterInputs
    outputs[rally.base_agent.RallyManagedOutputs]: "Outputs"
        override issue_note: "Saved Run Note"
            shared.outputs.WriterIssueNote

        poem_draft:
            shared.outputs.PoemDraft

        turn_result: "Turn Result"
            PoemWriterTurnResult
    skills: rally.base_agent.RallyManagedSkills
    final_output:
        output: PoemWriterTurnResult
        route: next_route


review PoemReview: "Poem Review"
    subject: shared.inputs.PoemDraftFile
    contract: shared.review.PoemReviewContract
    comment_output: shared.review.PoemReviewResponse

    fields:
        verdict: verdict
        reviewed_artifact: reviewed_artifact
        analysis: analysis_performed
        readback: findings_first
        current_artifact: current_artifact
        failing_gates: failure_detail.failing_gates
        blocked_gate: failure_detail.blocked_gate
        next_owner: next_owner

    basis_checks: "Basis Checks"
        block "The poem draft is missing." when shared.inputs.PoemDraftFile.basis_missing

    contract_checks: "Contract Checks"
        accept "The poem meets the review contract." when contract.passes

    on_accept: "If Accepted"
        current artifact shared.inputs.PoemDraftFile via shared.review.PoemReviewResponse.current_artifact

    on_reject: "If Rejected"
        when present(blocked_gate):
            current none

        when missing(blocked_gate):
            current artifact shared.inputs.PoemDraftFile via shared.review.PoemReviewResponse.current_artifact
            route "Poem needs another draft." -> Muse


agent PoemCritic[PoemLoopRole]:
    role: "Core job: judge the poem with a real review, hand it back when it needs work, and finish only when it is ready."
    inherit rally_contract
    inherit read_first
    inherit how_to_take_a_turn
    inherit system_context
    inherit ground_truth
    inherit primary_path
    your_job: roles.poem_critic.PoemCriticJob
    quality_bar: roles.poem_critic.PoemCriticQualityBar
    review: PoemReview
    inputs: PoemLoopInputs
    outputs: "Outputs"
        shared.review.PoemReviewResponse
        shared.review.PoemReviewFinalResponse
    skills: rally.base_agent.RallyManagedSkills
    final_output:
        output: shared.review.PoemReviewFinalResponse
        review_fields:
            verdict: verdict
            reviewed_artifact: reviewed_artifact
            analysis: analysis_performed
            readback: findings_first
            current_artifact: current_artifact
            blocked_gate: failure_detail.blocked_gate
            failing_gates: failure_detail.failing_gates
            next_owner: next_owner
