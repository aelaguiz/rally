import rally.base_agent
import rally.turn_results
import shared.inputs
import shared.outputs
import shared.contracts
import shared.review
import roles.poem_writer
import roles.poem_critic


inputs PoemLoopInputs[rally.base_agent.RallyManagedInputs]: "Inputs"
    inherit rally_workspace_dir

    inherit rally_run_id
    inherit rally_flow_code
    inherit rally_agent_slug
    inherit issue_ledger

    poem_draft_file: "Poem Draft File"
        shared.inputs.PoemDraftFile


output schema PoemWriterTurnResultSchema[rally.turn_results.BaseRallyTurnResultSchema]: "Poem Writer Turn Result Schema"
    inherit kind
    inherit next_owner
    inherit summary
    inherit reason
    inherit sleep_duration_seconds

    field inspiration: "Inspiration"
        type: string
        optional
        min_length: 1
        note: "Short image, mood, or idea that shaped the draft."


output shape PoemWriterTurnResultJson[rally.turn_results.BaseRallyTurnResultJson]: "Poem Writer Turn Result JSON"
    inherit kind
    override schema: PoemWriterTurnResultSchema

    override field_notes: "Field Notes"
        bullets rules:
            "Always send all six keys."
            "Use `null` for fields that do not apply."
            "`kind` tells Rally what to do next."
            "Use `handoff` with `next_owner`, `done` with `summary`, `blocker` with `reason`, and `sleep` with `reason` plus `sleep_duration_seconds`."
            "If you set `next_owner`, use the flow owner key, not the display name."
            "Set `inspiration` to one short phrase when you hand off a draft."
            "Use `null` for `inspiration` when you block or sleep."


output PoemWriterTurnResult[rally.turn_results.BaseRallyTurnResult]: "Poem Writer Turn Result"
    inherit target
    override shape: PoemWriterTurnResultJson
    inherit requirement

    inspiration: "Inspiration"
        "Name one short image, mood, or idea that shaped the draft."
        "Use `null` when you block or sleep."


abstract agent PoemLoopRole[rally.base_agent.RallyManagedBaseAgent]:
    inherit rally_contract
    inherit read_first
    inherit how_to_take_a_turn
    system_context: shared.contracts.PoemLoopSystemContext
    ground_truth: shared.contracts.IssueLedgerGroundTruth
    primary_path: shared.contracts.PrimaryPathRules


agent PoemWriter[PoemLoopRole]:
    role: "Core job: write the requested poem and hand it to PoemCritic."
    inherit rally_contract
    inherit read_first
    inherit how_to_take_a_turn
    inherit system_context
    inherit ground_truth
    inherit primary_path
    your_job: roles.poem_writer.PoemWriterJob
    quality_bar: roles.poem_writer.PoemWriterQualityBar
    inputs: PoemLoopInputs
    outputs[rally.base_agent.RallyManagedOutputs]: "Outputs"
        override issue_note: "Saved Run Note"
            shared.outputs.WriterIssueNote

        poem_draft: "Poem Draft"
            shared.outputs.PoemDraft

        turn_result: "Turn Result"
            PoemWriterTurnResult
    skills: rally.base_agent.RallyManagedSkills
    final_output: PoemWriterTurnResult


review PoemReview: "Poem Review"
    subject: shared.inputs.PoemDraftFile
    contract: shared.review.PoemReviewContract
    comment_output: shared.review.PoemReviewResponse

    fields:
        verdict: verdict
        reviewed_artifact: reviewed_artifact
        analysis: analysis_performed
        readback: findings_first
        current_artifact: current_artifact
        failing_gates: failure_detail.failing_gates
        blocked_gate: failure_detail.blocked_gate
        next_owner: next_owner

    basis_checks: "Basis Checks"
        block "The poem draft is missing." when shared.inputs.PoemDraftFile.basis_missing

    contract_checks: "Contract Checks"
        accept "The poem meets the review contract." when contract.passes

    on_accept: "If Accepted"
        current artifact shared.inputs.PoemDraftFile via shared.review.PoemReviewResponse.current_artifact

    on_reject: "If Rejected"
        when present(blocked_gate):
            current none

        when missing(blocked_gate):
            current artifact shared.inputs.PoemDraftFile via shared.review.PoemReviewResponse.current_artifact
            route "Poem needs another draft." -> PoemWriter


agent PoemCritic[PoemLoopRole]:
    role: "Core job: judge the poem with a real review, hand it back when it needs work, and finish only when it is ready."
    inherit rally_contract
    inherit read_first
    inherit how_to_take_a_turn
    inherit system_context
    inherit ground_truth
    inherit primary_path
    your_job: roles.poem_critic.PoemCriticJob
    quality_bar: roles.poem_critic.PoemCriticQualityBar
    review: PoemReview
    inputs: PoemLoopInputs
    outputs: "Outputs"
        shared.review.PoemReviewResponse
        shared.review.PoemReviewFinalResponse
    skills: rally.base_agent.RallyManagedSkills
    final_output:
        output: shared.review.PoemReviewFinalResponse
        review_fields:
            verdict: verdict
            reviewed_artifact: reviewed_artifact
            analysis: analysis_performed
            readback: findings_first
            current_artifact: current_artifact
            blocked_gate: failure_detail.blocked_gate
            failing_gates: failure_detail.failing_gates
            next_owner: next_owner
