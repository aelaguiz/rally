import rally.base_agent
import rally.currentness
import rally.turn_results


input WorkBrief: "Work Brief"
    source: Prompt
    shape: MarkdownDocument
    requirement: Required
    "Use the prompt brief as the work description for this smoke test."


input RoutingFacts: "Routing Facts"
    source: Prompt
    shape: JsonObject
    requirement: Required
    "Use the routing facts that say whether this smoke test should show the `current none` path while the same owner keeps the work."


output RepairPlan: "Repair Plan"
    target: File
        path: "artifacts/repair_plan.md"
    shape: MarkdownDocument
    requirement: Required
    "Write the repair plan to `artifacts/repair_plan.md`."


output PlanAuthorTurnResult: "Plan Author Turn Result"
    target: TurnResponse
    shape: rally.turn_results.RallyTurnResultJson
    requirement: Required

    purpose: "Purpose"
        "End the plan-author turn with one Rally result JSON."
        "Use `handoff` with `next_owner` when the smoke test continues to RouteRepair."


output RouteRepairTurnResult: "Route Repair Turn Result"
    target: TurnResponse
    shape: rally.turn_results.RallyTurnResultJson
    requirement: Required

    purpose: "Purpose"
        "End the route-repair turn with one Rally result JSON."
        "Use `handoff` with `next_owner` when RouteRepair keeps the issue local."


output CloseoutTurnResult: "Closeout Turn Result"
    target: TurnResponse
    shape: rally.turn_results.RallyTurnResultJson
    requirement: Required

    purpose: "Purpose"
        "End the closeout turn with one Rally result JSON."
        "Use `done` with `summary` to finish the smoke test."


workflow PlanAuthorWorkflow[rally.currentness.RallyCarryCurrentArtifactConvention]: "Plan Author Workflow"
    inherit when_to_use
    inherit law_form
    inherit carrier_rule
    inherit pickup_rule

    smoke_note: "Smoke Note"
        "This smoke test keeps `artifacts/repair_plan.md` as the one file that still matters."

    law:
        current artifact RepairPlan via rally.currentness.RallyCurrentArtifactCarry.current_artifact


agent PlanAuthor[rally.base_agent.RallyManagedBaseAgent]:
    role: "Draft the repair plan and make it clear which file stays current."
    workflow: PlanAuthorWorkflow
    inherit rally_contract
    inputs[rally.base_agent.RallyManagedInputs]: "Inputs"
        inherit rally_base_dir
        inherit rally_run_id
        inherit rally_flow_code

        work_brief: "Work Brief"
            WorkBrief
    outputs: "Outputs"
        RepairPlan
        PlanAuthorTurnResult
        rally.currentness.RallyCurrentArtifactCarry
    handoff_routing: "Handoff Routing"
        if_the_smoke_should_continue_into_route_repair: "If The Smoke Should Continue Into Route Repair"
            route "Send the smoke test issue to RouteRepair." -> RouteRepair
    final_output: PlanAuthorTurnResult


workflow RouteRepairWorkflow[rally.currentness.RallyNoCurrentArtifactConvention]: "Route Repair Workflow"
    inherit when_to_use
    inherit law_form
    inherit pickup_rule

    smoke_note: "Smoke Note"
        "This smoke test shows the `current none` path while the same owner keeps the work."

    law:
        active when RoutingFacts.needs_route_repair
        current none
        stop "No file stays current yet, so the same owner keeps the issue until the fix is done."


agent RouteRepair[rally.base_agent.RallyManagedBaseAgent]:
    role: "Keep the smoke test local with `current none` when no file stays current yet."
    workflow: RouteRepairWorkflow
    inherit rally_contract
    inputs[rally.base_agent.RallyManagedInputs]: "Inputs"
        inherit rally_base_dir
        inherit rally_run_id
        inherit rally_flow_code

        routing_facts: "Routing Facts"
            RoutingFacts
    outputs: "Outputs"
        RouteRepairTurnResult
    handoff_routing: "Handoff Routing"
        if_local_route_repair_must_continue: "If Local Route Repair Must Continue"
            route "Keep the smoke test issue with RouteRepair until the fix is done." -> RouteRepair
    final_output: RouteRepairTurnResult


workflow CloseoutWorkflow: "Closeout Workflow"
    "End the smoke test with one final `done` result."


agent Closeout[rally.base_agent.RallyManagedBaseAgent]:
    role: "End the smoke test with a final `done` result."
    workflow: CloseoutWorkflow
    inherit rally_contract
    outputs: "Outputs"
        CloseoutTurnResult
    final_output: CloseoutTurnResult
