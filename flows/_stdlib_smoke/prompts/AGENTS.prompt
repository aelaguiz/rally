import rally.base_agent
import rally.review_results
import rally.turn_results


enum SmokeRoute: "Smoke Route"
    closeout: "Closeout"
    retry: "Retry"


input WorkBrief: "Work Brief"
    source: Prompt
    shape: MarkdownDocument
    requirement: Required
    "Use the prompt brief as the work description for this smoke test."


input RoutingFacts: "Routing Facts"
    source: Prompt
    shape: JsonObject
    requirement: Required
    "Use the routing facts that say whether the smoke test needs one more step."


input RepairPlanReviewFile: "Repair Plan Review File"
    source: File
        path: "home:artifacts/repair_plan.md"
    shape: MarkdownDocument
    requirement: Required
    basis_missing: "Basis Missing"
    "Use the repair plan file as the review subject for the smoke test."


output RepairPlan: "Repair Plan"
    target: File
        path: "home:artifacts/repair_plan.md"
    shape: MarkdownDocument
    requirement: Required
    "Write the repair plan to `home:artifacts/repair_plan.md`."


output PlanAuthorTurnResult: "Plan Author Turn Result"
    target: TurnResponse
    shape: rally.turn_results.RallyTurnResultJson
    requirement: Required

    kind: "handoff" when route.exists
    next_owner: route.next_owner.key when route.exists

    kind: "done" when route.exists == false
    summary: "Write one short closeout summary." when route.exists == false


output RouteRepairDecision: "Route Repair Decision"
    target: TurnResponse
    shape: Comment
    requirement: Required

    route_choice: "Route Choice"
        "Use `closeout` to finish the smoke test and `retry` to send it back for one more pass."


output RouteRepairTurnResult: "Route Repair Turn Result"
    target: TurnResponse
    shape: rally.turn_results.RallyTurnResultJson
    requirement: Required

    kind: "handoff"
    next_owner: route.next_owner.key


output schema CloseoutTurnResultSchema[rally.turn_results.BaseRallyTurnResultSchema]: "Closeout Turn Result Schema"
    inherit kind
    inherit next_owner
    inherit summary
    inherit reason
    inherit sleep_duration_seconds

    field current_artifact: "Current Artifact"
        type: string
        optional
        min_length: 1
        note: "Current artifact path when the smoke test closes out."

    override example:
        kind: "done"
        next_owner: null
        summary: "Repair plan is written and the smoke test is done."
        reason: null
        sleep_duration_seconds: null
        current_artifact: "home:artifacts/repair_plan.md"


output shape CloseoutTurnResultJson[rally.turn_results.BaseRallyTurnResultJson]: "Closeout Turn Result JSON"
    inherit kind
    override schema: CloseoutTurnResultSchema
    inherit field_notes


output CloseoutTurnResult[rally.turn_results.BaseRallyTurnResult]: "Closeout Turn Result"
    inherit target
    override shape: CloseoutTurnResultJson
    inherit requirement

    kind: "done"
    summary: "Write one short closeout summary."
    current_artifact: "home:artifacts/repair_plan.md"


output schema SmokeReviewSchema[rally.review_results.BaseRallyReviewSchema]: "Smoke Review Schema"
    inherit verdict
    inherit reviewed_artifact
    inherit analysis_performed
    inherit findings_first
    inherit current_artifact
    inherit next_owner
    inherit failure_detail

    override example:
        verdict: "accept"
        reviewed_artifact: "home:artifacts/repair_plan.md"
        analysis_performed: "The repair plan is present and the smoke review can keep it."
        findings_first: "The repair plan is ready to keep."
        current_artifact: "home:artifacts/repair_plan.md"
        next_owner: null
        failure_detail: null


output shape SmokeReviewJson[rally.review_results.BaseRallyReviewJson]: "Smoke Review JSON"
    inherit kind
    override schema: SmokeReviewSchema
    inherit field_notes


output SmokeReviewResponse[rally.review_results.BaseRallyReviewResponse]: "Smoke Review Response"
    inherit target
    override shape: SmokeReviewJson
    inherit requirement
    inherit verdict
    inherit reviewed_artifact
    inherit analysis_performed
    inherit findings_first
    inherit current_artifact
    inherit next_owner
    inherit failure_detail
    inherit trust_surface
    inherit standalone_read


output SmokeReviewFinalResponse: "Smoke Review Final Response"
    target: TurnResponse
    shape: SmokeReviewJson
    requirement: Required

    verdict: "Verdict"
        "Say whether the review accepts the work or asks for changes."

    reviewed_artifact: "Reviewed Artifact"
        "Use `home:artifacts/repair_plan.md`."

    analysis_performed: "Review Summary"
        "Explain the review in 2-4 plain sentences."

    findings_first: "Findings First"
        "Start with the main finding, then the next move."
        "Keep it short and plain."

    current_artifact: "Current Artifact" when present(current_artifact):
        "Use `home:artifacts/repair_plan.md` when the repair plan still stands."

    next_owner: "Next Owner" when present(next_owner):
        "Use the next owner key when the review routes."

    failure_detail: "Failure Detail" when verdict == ReviewVerdict.changes_requested:
        blocked_gate: "Blocked Gate" when present(blocked_gate):
            "Name the blocker when review could not start."

        failing_gates: "Failing Gates"
            "List the exact failing review gates in authored order."

    trust_surface:
        current_artifact

    standalone_read: "Standalone Read"
        "This final JSON should be enough for Rally to read the review outcome."


schema SmokeReviewContract: "Smoke Review Contract"
    sections:
        summary: "Summary"
            "Summarize whether the repair plan is ready to keep."

    gates:
        artifact_named: "Artifact Named"
            "Confirm the review names the repair plan path."


review SmokeReview: "Smoke Review"
    subject: RepairPlanReviewFile
    contract: SmokeReviewContract
    comment_output: SmokeReviewResponse

    fields:
        verdict: verdict
        reviewed_artifact: reviewed_artifact
        analysis: analysis_performed
        readback: findings_first
        current_artifact: current_artifact
        blocked_gate: failure_detail.blocked_gate
        failing_gates: failure_detail.failing_gates
        next_owner: next_owner

    basis_checks: "Basis Checks"
        block "The repair plan is missing." when RepairPlanReviewFile.basis_missing

    contract_checks: "Contract Checks"
        accept "The smoke review contract passes." when contract.passes

    on_accept:
        current artifact RepairPlanReviewFile via SmokeReviewResponse.current_artifact

    on_reject:
        current artifact RepairPlanReviewFile via SmokeReviewResponse.current_artifact


agent PlanAuthor[rally.base_agent.RallyManagedBaseAgent]:
    role: "Write the repair plan and either pass the smoke test forward or finish it."
    inherit rally_contract
    inherit read_first
    inherit how_to_take_a_turn
    workflow: "Plan"
        "Write `home:artifacts/repair_plan.md`."
        "Pass the smoke test to RouteRepair only when it needs one more step."
        "Otherwise finish the smoke test here."
    inputs[rally.base_agent.RallyManagedInputs]: "Inputs"
        inherit rally_workspace_dir
        inherit rally_run_id
        inherit rally_flow_code
        inherit rally_agent_slug
        inherit issue_ledger

        work_brief: "Work Brief"
            WorkBrief

        routing_facts: "Routing Facts"
            RoutingFacts
    outputs[rally.base_agent.RallyManagedOutputs]: "Outputs"
        inherit issue_note

        repair_plan: "Repair Plan"
            RepairPlan

        turn_result: "Turn Result"
            PlanAuthorTurnResult
    handoff_routing: "Handoff Routing"
        law:
            active when true
            stop "Hand off or finish the smoke test."
            route "Send the smoke test to RouteRepair." -> RouteRepair when RoutingFacts.needs_route_repair
    final_output: PlanAuthorTurnResult


agent RouteRepair[rally.base_agent.RallyManagedBaseAgent]:
    role: "Pick the next smoke-test owner from the emitted route choice."
    inherit rally_contract
    inherit read_first
    inherit how_to_take_a_turn
    workflow: "Route Repair"
        "Choose whether the smoke test should close out now or loop back for one more pass."
    outputs[rally.base_agent.RallyManagedOutputs]: "Outputs"
        inherit issue_note

        route_decision: "Route Decision"
            RouteRepairDecision

        turn_result: "Turn Result"
            RouteRepairTurnResult
    handoff_routing: "Handoff Routing"
        law:
            route_from RouteRepairDecision.route_choice as SmokeRoute:
                SmokeRoute.closeout:
                    route "Send the smoke test to Closeout." -> Closeout
                SmokeRoute.retry:
                    route "Send the smoke test back to PlanAuthor." -> PlanAuthor
    final_output: RouteRepairTurnResult


agent Closeout[rally.base_agent.RallyManagedBaseAgent]:
    role: "End the smoke test with a final `done` result."
    inherit rally_contract
    inherit read_first
    inherit how_to_take_a_turn
    workflow: "Closeout"
        "End the smoke test with one final `done` result."
    outputs[rally.base_agent.RallyManagedOutputs]: "Outputs"
        inherit issue_note

        turn_result: "Turn Result"
            CloseoutTurnResult
    final_output: CloseoutTurnResult


agent RepairPlanReviewer:
    role: "Review the smoke repair plan and end with split review JSON."
    review: SmokeReview
    inputs: "Inputs"
        RepairPlanReviewFile
    outputs: "Outputs"
        SmokeReviewResponse
        SmokeReviewFinalResponse
    final_output:
        output: SmokeReviewFinalResponse
        review_fields:
            verdict: verdict
            reviewed_artifact: reviewed_artifact
            analysis: analysis_performed
            readback: findings_first
            current_artifact: current_artifact
            blocked_gate: failure_detail.blocked_gate
            failing_gates: failure_detail.failing_gates
            next_owner: next_owner
