import rally.handoffs
import rally.currentness
import rally.notes
import rally.turn_results


input WorkBrief: "Work Brief"
    source: Prompt
    shape: MarkdownDocument
    requirement: Required
    "Use the prompt brief as the work description for the smoke flow."


input RoutingFacts: "Routing Facts"
    source: Prompt
    shape: JsonObject
    requirement: Required
    "Use the routing facts that say whether the smoke should demonstrate the shared no-current local-repair path."


output RepairPlan: "Repair Plan"
    target: File
        path: "artifacts/repair_plan.md"
    shape: MarkdownDocument
    requirement: Required
    "Write the current repair plan to a flow-owned artifact."


output PlanAuthorTurnResult: "Plan Author Turn Result"
    target: TurnResponse
    shape: rally.turn_results.RallyTurnResultJson
    requirement: Required

    purpose: "Purpose"
        "End the plan-author turn with one structured Rally turn result."


output RouteRepairTurnResult: "Route Repair Turn Result"
    target: TurnResponse
    shape: rally.turn_results.RallyTurnResultJson
    requirement: Required

    purpose: "Purpose"
        "End the route-repair turn with one structured Rally turn result."


output CloseoutTurnResult: "Closeout Turn Result"
    target: TurnResponse
    shape: rally.turn_results.RallyTurnResultJson
    requirement: Required

    purpose: "Purpose"
        "End the closeout turn with one structured Rally turn result."


workflow PlanAuthorWorkflow[rally.currentness.RallyCarryCurrentArtifactConvention]: "Plan Author Workflow"
    inherit when_to_use
    inherit law_form
    inherit carrier_rule
    inherit pickup_rule

    smoke_note: "Smoke Note"
        "This smoke keeps `artifacts/repair_plan.md` as the durable current artifact."

    law:
        current artifact RepairPlan via rally.handoffs.RallyCurrentArtifactHandoff.current_artifact


agent PlanAuthor:
    role: "Draft the repair plan and leave one current-artifact handoff."
    workflow: PlanAuthorWorkflow
    inputs: "Inputs"
        WorkBrief
    outputs: "Outputs"
        RepairPlan
        PlanAuthorTurnResult
        rally.notes.RallyIssueNote
        rally.handoffs.RallyCurrentArtifactHandoff
    final_output: PlanAuthorTurnResult


workflow RouteRepairWorkflow[rally.currentness.RallyNoCurrentArtifactConvention]: "Route Repair Workflow"
    inherit when_to_use
    inherit law_form
    inherit pickup_rule

    smoke_note: "Smoke Note"
        "This smoke proves the no-current handoff path while ownership stays local."

    law:
        active when RoutingFacts.needs_route_repair
        current none
        stop "No durable artifact is current yet, so the same owner keeps the issue until repair completes."


agent RouteRepair:
    role: "Leave the shared no-current handoff when the smoke is only repairing locally."
    workflow: RouteRepairWorkflow
    inputs: "Inputs"
        RoutingFacts
    outputs: "Outputs"
        RouteRepairTurnResult
        rally.notes.RallyIssueNote
        rally.handoffs.RallyNoCurrentArtifactHandoff
    final_output: RouteRepairTurnResult


workflow CloseoutWorkflow: "Closeout Workflow"
    "End the smoke with one terminal done result."


agent Closeout:
    role: "End the smoke with a terminal done result."
    workflow: CloseoutWorkflow
    outputs: "Outputs"
        rally.notes.RallyIssueNote
        CloseoutTurnResult
    final_output: CloseoutTurnResult
