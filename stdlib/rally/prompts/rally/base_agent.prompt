# This module is the shared base for normal Rally work turns.
# It owns the run-local ledger input and saved note output. Memory stays opt-in
# in `rally.memory` so a flow chooses it on purpose.

# Use a tiny text shape for runtime env values.
# Keep these inputs available for flows that truly need them, but do not make
# them part of every managed role's always-on readback.
output shape RallyEnvText: "Rally Env Text"
    kind: PlainText


input RallyWorkspaceDir: "Rally Workspace Dir"
    source: EnvVar
        env: "RALLY_WORKSPACE_DIR"
    shape: DirectoryPath
    requirement: Required
    "Read this environment variable as the absolute path to the active Rally workspace root."


input RallyRunId: "Rally Run ID"
    source: EnvVar
        env: "RALLY_RUN_ID"
    shape: RallyEnvText
    requirement: Required
    "Read this environment variable as the active Rally run id."


input RallyFlowCode: "Rally Flow Code"
    source: EnvVar
        env: "RALLY_FLOW_CODE"
    shape: RallyEnvText
    requirement: Required
    "Read this environment variable as the active Rally flow code."


input RallyAgentSlug: "Rally Agent Slug"
    source: EnvVar
        env: "RALLY_AGENT_SLUG"
    shape: RallyEnvText
    requirement: Required
    "Read this environment variable as the active compiled agent slug for this turn."


# Declare the mandatory helper as a Doctrine skill once.
# `RallyManagedSkills` can include it by reference, and flows can inherit the
# shared skills block instead of copying skill prose.
skill RallyKernelSkill: "rally-kernel"
    purpose: "Use the shared Rally kernel skill when you need one saved note on this turn."


# This read-first block stays small on purpose.
# It teaches the one shared habit every Rally agent should keep.
# A workflow is the right Doctrine form here because this is turn behavior, not
# a tool, input, output, or review rule.
workflow RallyReadFirst: "Read First"
    sequence steps:
        "Read `home:issue.md` from the top, even if you've read it before."
        "Then read this role's local rules, files, and outputs."


# Keep shared turn rules in one workflow so flow prompts can inherit them or
# add local rules nearby without restating Rally's base rules.
workflow RallyHowToTakeATurn: "Shared Rules"
    bullets rules:
        "Use `home:issue.md` as the shared ledger for this run."
        "Leave one short saved note through `Saved Run Note` only when later readers need it."
        "End the turn with the final JSON this turn declares."
        "Keep routing, `done`, `blocker`, and `sleep` in final JSON, not in notes."


# Keep the always-on input block to the one shared ledger file.
# Flows can opt into the env inputs below only when their authored prompt really
# needs them.
inputs RallyManagedInputs: "Inputs"
    issue_ledger:
        RallyIssueLedger


inputs RallyRuntimeEnvInputs: "Runtime Env Inputs"
    rally_workspace_dir:
        RallyWorkspaceDir

    rally_run_id:
        RallyRunId

    rally_flow_code:
        RallyFlowCode

    rally_agent_slug:
        RallyAgentSlug


# Group mandatory Rally skills the same way.
# This keeps the base agent lean while still making every managed turn expose
# the one note helper Rally provides.
skills RallyManagedSkills: "Skills"
    skill rally_kernel: RallyKernelSkill
        requirement: Required

# The render profile keeps saved context compact when Doctrine emits it.
# It changes emitted text only. It is not another runtime state path.
render_profile CompactSavedContext:
    properties -> sentence


output target RallyIssueNoteAppend: "Rally Issue Note Append"
    delivery_skill: RallyKernelSkill

# This module owns Rally's shared run ledger file.
# Keep the path here so flows import one input instead of spelling their own
# sidecar files or raw note paths.
input RallyIssueLedger: "Issue Ledger"
    source: File
        path: "home:issue.md"
    shape: MarkdownDocument
    requirement: Required

# A saved note is advisory because notes are for later readers.
# Routing, `done`, `blocker`, and `sleep` still belong to the declared final
# JSON for the turn.
output RallyIssueNote: "Issue Note"
    target: RallyIssueNoteAppend
    shape: MarkdownDocument
    render_profile: CompactSavedContext
    requirement: Advisory

    properties saved_context: "Saved Context"
        when_to_use: "When To Use"
            "Leave one short note only when a later reader needs context."

# The saved note output is advisory by design.
# Final JSON owns routing and completion, while this output is only for context
# a later turn should remember.
outputs RallyManagedOutputs: "Outputs"
    issue_note: "Saved Run Note"
        RallyIssueNote


# This shared base block is where Rally states repo-wide turn rules once.
# Local flows can add more rules, but they should not fight this base layer.
# `abstract agent` is the Doctrine pattern that lets flow roles inherit the
# shared shape without creating a runnable stdlib-only agent.
abstract agent RallyManagedBaseAgent:
    rally_contract: "Rally Context"
        "Rally is the shared control plane for this run. It gives you the shared ledger, shared skills, and the next route."
    read_first: RallyReadFirst
    how_to_take_a_turn: RallyHowToTakeATurn

    inputs: RallyManagedInputs
    skills: RallyManagedSkills
    outputs: RallyManagedOutputs
