import rally.notes


output shape RallyEnvText: "Rally Env Text"
    kind: PlainText


input RallyWorkspaceDir: "Rally Workspace Dir"
    source: EnvVar
        env: "RALLY_WORKSPACE_DIR"
    shape: DirectoryPath
    requirement: Required
    "Read this environment variable as the absolute path to the active Rally workspace root."


input RallyRunId: "Rally Run ID"
    source: EnvVar
        env: "RALLY_RUN_ID"
    shape: RallyEnvText
    requirement: Required
    "Read this environment variable as the active Rally run id."


input RallyFlowCode: "Rally Flow Code"
    source: EnvVar
        env: "RALLY_FLOW_CODE"
    shape: RallyEnvText
    requirement: Required
    "Read this environment variable as the active Rally flow code."


skill RallyKernelSkill: "rally-kernel"
    purpose: "Use the shared Rally kernel skill to leave notes when needed and end the turn with the declared final JSON."

    use_when: "Use When"
        "Use this when a later reader needs a note."
        "Use this when the turn needs Rally's shared final JSON rules."


inputs RallyManagedInputs: "Inputs"
    rally_workspace_dir: "Rally Workspace Dir"
        RallyWorkspaceDir

    rally_run_id: "Rally Run ID"
        RallyRunId

    rally_flow_code: "Rally Flow Code"
        RallyFlowCode


skills RallyManagedSkills: "Skills"
    skill rally_kernel: RallyKernelSkill
        requirement: Required
        reason: "Rally provides this skill on every Rally-managed turn."


outputs RallyManagedOutputs: "Outputs"
    issue_note: "Issue Note"
        rally.notes.RallyIssueNote


abstract agent RallyManagedBaseAgent:
    rally_contract: "Rally Rules"
        "Rally owns the run home, the note path, and the final JSON for this turn."
        "End the turn with the final JSON shape this turn declares."
        "Many Rally turns use `rally.turn_results.RallyTurnResult`."
        "Review-native turns may end with Doctrine review JSON that Rally can read."
        "Leave a note only when a later reader needs context."
        "If Rally already saves the final review to `issue.md`, do not leave a second note unless the flow asks for one."
        "Use the shared `rally-kernel` skill for that note."
        "Do not edit `home/issue.md` directly."
        "Read run identity from `RALLY_WORKSPACE_DIR`, `RALLY_RUN_ID`, and `RALLY_FLOW_CODE`."
        "Use `RALLY_CLI_BIN` when a flow tells you to call the Rally CLI."

    inputs: RallyManagedInputs
    skills: RallyManagedSkills
    outputs: RallyManagedOutputs
